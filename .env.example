# ============================================================
# DigiAds MediaCrawler Kit — biến môi trường mẫu
# Copy thành .env và điền giá trị. KHÔNG commit .env thật.
# ============================================================

# --- AI (chuỗi prompt Angle → Video Brief, sinh Trend Brief) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# --- REST API của MediaCrawler (analyzer/mcp gọi vào) ---
MEDIACRAWLER_API=http://127.0.0.1:8080

# --- Supabase (Tier 1: kho dữ liệu + dashboard) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...            # service_role hoặc key có quyền ghi

# --- Thông báo (n8n / Zalo / Slack webhook) ---
NOTIFY_WEBHOOK_URL=https://n8n.digiads.vn/webhook/xxxx

# --- Hàng đợi job (Tier 2: arq) ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- Tùy chọn dịch ZH→VI (nếu dùng dịch vụ ngoài thay vì Claude) ---
# TRANSLATE_PROVIDER=claude            # claude | none
